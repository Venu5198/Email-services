# ─────────────────────────────────────────────────────────────────────────────
# SyncRivo Email Service — Environment Variables Template
# Copy this file to .env and fill in your real values:
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# Email Provider (smtp | sendgrid | ses)
EMAIL_PROVIDER=smtp

# Default Sender
DEFAULT_SENDER_EMAIL=your.email@gmail.com

# SMTP Settings (Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USERNAME=your.email@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx
SMTP_USE_TLS=false
SMTP_USE_SSL=true

# SendGrid (optional)
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=your.email@gmail.com

# AWS SES (optional)
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMIK/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_REGION=us-east-1
AWS_SES_FROM_EMAIL=your.email@gmail.com

# Attachment Limits
MAX_ATTACHMENT_SIZE_MB=10
MAX_TOTAL_ATTACHMENT_SIZE_MB=25

# Retry Configuration
RETRY_ATTEMPTS=3
RETRY_BACKOFF_MIN=1
RETRY_BACKOFF_MAX=10

# Logging
LOG_LEVEL=INFO

# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=email_service
ENABLE_MONGO_LOGGING=true
ENABLE_MONGO_TEMPLATES=true
